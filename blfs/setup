# =============================================================================
# 25. Rust toolchain
# =============================================================================
if ! step_done rust; then
  header "Rust toolchain"
  if ! command -v rustc &>/dev/null; then
    fetch "https://static.rust-lang.org/rustup/dist/x86_64-unknown-linux-gnu/rustup-init"
    chmod +x "$SOURCES/rustup-init"
    RUSTUP_HOME=/usr/share/rustup CARGO_HOME=/usr/share/cargo \
      "$SOURCES/rustup-init" -y --no-modify-path \
        --default-toolchain stable --profile minimal
  fi
  cat > /etc/profile.d/rust.sh << 'EOF'
export RUSTUP_HOME=/usr/share/rustup
export CARGO_HOME=/usr/share/cargo
export PATH="$CARGO_HOME/bin:$PATH"
EOF
  source /etc/profile.d/rust.sh
  mark_step rust
fi
source /etc/profile.d/rust.sh 2>/dev/null || true


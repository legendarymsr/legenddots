# =============================================================================
# 46. User setup — legend
# =============================================================================
if ! step_done user_setup; then
  header "User setup — legend"
  groupadd -f wheel; groupadd -f seat; groupadd -f render; groupadd -f video
  groupadd -f audio; groupadd -f input
  useradd -m -G wheel,audio,video,render,input,seat \
          -s /bin/zsh legend 2>/dev/null || true
  echo "legend:$(openssl passwd -6 'legendary')" | chpasswd -e

  if command -v doas &>/dev/null; then
    printf 'permit persist legend as root\n' > /etc/doas.conf
    chmod 0400 /etc/doas.conf
  else
    warn "doas not found — configure sudo or doas manually for 'legend'"
  fi

  su - legend -c "
    git clone https://github.com/legendarymsr/legenddots ~/legenddots 2>/dev/null || \
      (cd ~/legenddots && git pull --ff-only)
    mkdir -p ~/Pictures/Screenshots
    mkdir -p ~/.config/alacritty ~/.config/niri ~/.config/fastfetch
    ln -sfn ~/legenddots/alacritty.toml         ~/.config/alacritty/alacritty.toml
    ln -sfn ~/legenddots/.zshrc                 ~/.zshrc
    ln -sfn ~/legenddots/niri/config.kdl        ~/.config/niri/config.kdl
    ln -sfn ~/legenddots/niri/waybar            ~/.config/waybar
    ln -sfn ~/legenddots/niri/fuzzel            ~/.config/fuzzel
    ln -sfn ~/legenddots/niri/dunst             ~/.config/dunst
    ln -sfn ~/legenddots/niri/swaylock          ~/.config/swaylock
    ln -sfn ~/legenddots/wallpapers            ~/.config/wallpapers
    ln -sfn ~/legenddots/fastfetch/config.jsonc ~/.config/fastfetch/config.jsonc
  "
  mark_step user_setup
fi

# =============================================================================
# 47. KVM/QEMU hardware setup
# =============================================================================
if ! step_done kvm_hw; then
  header "KVM/QEMU hardware config"
  mkdir -p /etc/udev/rules.d
  cat > /etc/udev/rules.d/99-virtio-gpu.rules << 'EOF'
SUBSYSTEM=="drm", KERNEL=="card*", GROUP="video", MODE="0660"
SUBSYSTEM=="drm", KERNEL=="renderD*", GROUP="render", MODE="0660"
EOF
  mark_step kvm_hw
fi

echo -e "\n${GREEN}Setup complete.${NC}"
echo -e "${CYAN}Estimated build time on KVM (2 vCPU, 4 GB): 50–70 hours (LLVM is the bottleneck).${NC}"
echo -e "${CYAN}Reboot and start a niri session as 'legend'.${NC}"

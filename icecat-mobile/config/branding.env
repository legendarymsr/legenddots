# IceCat-for-Android branding configuration
# Edit these values to customize the rebrand. Sourced by scripts/*.sh.

# Display name shown to users (launcher, about screen, etc.)
APP_NAME="IceCat"

# F-Droid repo hosting the upstream browser to repackage.
# scripts/download-apk.sh reads this repo's index-v1.json to find the latest
# APK for UPSTREAM_PACKAGE_ID/UPSTREAM_ABI.
#
# Upstream is Fennec F-Droid: Mozilla's own de-Googled Firefox/Fenix build,
# published on the official F-Droid repo. (DivestOS's Mull, the previous
# choice, was deprecated/archived in favor of Fennec F-Droid in early 2025.)
UPSTREAM_FDROID_REPO="https://f-droid.org/repo"

# Upstream's Android package ID.
UPSTREAM_PACKAGE_ID="org.mozilla.fennec_fdroid"

# Device ABI to fetch (arm64-v8a covers most modern phones).
UPSTREAM_ABI="arm64-v8a"

# Apply Arkenfox/Mull/Tor-Browser-inspired privacy & security hardening
# prefs from branding/hardening-prefs.js (Enhanced Tracking Protection
# "strict", Resist Fingerprinting, HTTPS-Only mode, DNS over HTTPS, opt out
# of remote experiments, etc.) on top of Fennec F-Droid's own defaults. Set
# to "false" for a pure rebrand with no behavior changes.
ENABLE_HARDENING="true"

# Default search engine, set via assets/search/list.json's
# `default.searchDefault`. Must match one of the engine names in that
# file's `default.searchOrder`/`visibleDefaultEngines` (e.g. "Brave",
# "DuckDuckGo", "Ecosia", "Mojeek", "Startpage", "Wikipedia").
DEFAULT_SEARCH_ENGINE="Brave"

# IceCat accent color (6 hex digits, no '#'), applied to Fenix's primary
# accent color (res/values/colors.xml `photonInk20`/`photonInk20A20`) —
# used for the address bar, buttons, links, and other highlighted UI.
ICECAT_ACCENT_COLOR="0EA5E9"

# EXPERIMENTAL, default off. Pre-installs GNU LibreJS, uBlock Origin,
# Privacy Badger, and Dark Reader as built-in (auto-enabled, no-tap)
# WebExtensions by patching Fenix's decompiled bytecode (smali) to register
# them the same way Fenix registers its own built-ins (reader view, browser
# icons, etc.) via GeckoView's ensureBuiltIn/installBuiltInWebExtension.
# Unlike the rest of this pipeline, this is NOT a pure resource/string
# rebrand -- it edits compiled app code and has not been verified on a real
# device. Worst case it could crash the browser on startup (recoverable: see
# README's "Bundled extensions (experimental)" section). The published
# icecat-latest release is built with this flag off.
BUNDLE_EXTENSIONS="false"

# Working/output directories
WORK_DIR="build"
DIST_DIR="dist"

# Signing key used to re-sign the repackaged APK. This is a throwaway key
# committed to the repo (keystore/icecat-release.keystore) — it exists only
# so sideloaded builds from this repo can be reinstalled/updated without
# uninstalling first. It carries no trust; do not treat it as official.
KEYSTORE="keystore/icecat-release.keystore"
KEYSTORE_ALIAS="icecat"
KEYSTORE_PASS="icecat-throwaway"

# =============================================================================
# 43. brightnessctl
# =============================================================================
if ! step_done brightnessctl; then
  header "brightnessctl ${BRIGHTNESSCTL_VER}"
  a=$(fetch "https://github.com/Hummer12007/brightnessctl/archive/refs/tags/${BRIGHTNESSCTL_VER}.tar.gz")
  bpkg "$a" bash -c "
    make -j${NPROC}
    make install PREFIX=/usr
  "
  # udev rule for backlight control without root
  cat > /etc/udev/rules.d/90-backlight.rules << 'EOF'
ACTION=="add", SUBSYSTEM=="backlight", \
  RUN+="/bin/chgrp video /sys/class/backlight/%k/brightness", \
  RUN+="/bin/chmod g+w   /sys/class/backlight/%k/brightness"
EOF
  mark_step brightnessctl
fi

# =============================================================================
# 44. fastfetch
# =============================================================================
if ! step_done fastfetch; then
  header "fastfetch (latest)"
  FF_VER="2.26.1"
  a=$(fetch "https://github.com/fastfetch-cli/fastfetch/archive/refs/tags/${FF_VER}.tar.gz")
  bpkg "$a" bash -c "
    cmake -DCMAKE_INSTALL_PREFIX=/usr \
          -DCMAKE_BUILD_TYPE=Release   \
          -G Ninja .
    ninja -j${NPROC}
    ninja install
  "
  mark_step fastfetch
fi

# =============================================================================
# 45. Fonts
# =============================================================================
if ! step_done fonts; then
  header "Fonts — JetBrainsMono Nerd Font + Noto Emoji"
  mkdir -p /usr/share/fonts/nerd-fonts /usr/share/fonts/noto

  # JetBrainsMono Nerd Font
  jb_url="https://github.com/ryanoasis/nerd-fonts/releases/download/v3.2.1/JetBrainsMono.tar.xz"
  jb_a=$(fetch "$jb_url")
  tar -xf "$jb_a" -C /usr/share/fonts/nerd-fonts

  # Noto Emoji
  noto_url="https://github.com/googlefonts/noto-emoji/raw/main/fonts/NotoColorEmoji.ttf"
  wget -q -O /usr/share/fonts/noto/NotoColorEmoji.ttf "$noto_url"

  fc-cache -fv
  mark_step fonts
fi

# =============================================================================
# 46. User setup — legend
# =============================================================================
if ! step_done user_setup; then
  header "User setup — legend"
  groupadd -f seat; groupadd -f render; groupadd -f video
  groupadd -f audio; groupadd -f input
  useradd -m -G wheel,audio,video,render,input,seat \
          -s /bin/zsh legend 2>/dev/null || true
  echo "legend:$(openssl passwd -6 'legendary')" | chpasswd -e

  # doas
  if ! command -v doas &>/dev/null; then
    warn "doas not found — configure sudo or doas manually for 'legend'"
  else
    printf 'permit persist legend as root\n' > /etc/doas.conf
    chmod 0400 /etc/doas.conf
  fi

  # Symlink configs from legenddots
  su - legend -c "
    git clone https://github.com/legendarymsr/legenddots ~/legenddots 2>/dev/null || \
      (cd ~/legenddots && git pull --ff-only)
    mkdir -p ~/Pictures/Screenshots
    mkdir -p ~/.config/alacritty ~/.config/niri ~/.config/fastfetch
    ln -sfn ~/legenddots/alacritty.toml         ~/.config/alacritty/alacritty.toml
    ln -sfn ~/legenddots/.zshrc                 ~/.zshrc
    ln -sfn ~/legenddots/niri/config.kdl        ~/.config/niri/config.kdl
    ln -sfn ~/legenddots/niri/waybar            ~/.config/waybar
    ln -sfn ~/legenddots/niri/fuzzel            ~/.config/fuzzel
    ln -sfn ~/legenddots/niri/dunst             ~/.config/dunst
    ln -sfn ~/legenddots/niri/swaylock          ~/.config/swaylock
    ln -sfn ~/legenddots/fastfetch/config.jsonc ~/.config/fastfetch/config.jsonc
  "
  mark_step user_setup
fi

# =============================================================================
# 47. MacBook Air 6,2 — hardware quirks
# =============================================================================
if ! step_done macbook_hw; then
  header "MacBook Air 6,2 hardware config"

  # Apple keyboard: fn keys act as standard F1-F12
  echo "options hid_apple fnmode=2" > /etc/modprobe.d/hid_apple.conf

  # Broadcom BCM4360 WiFi — must be built separately; broadcom-sta is non-free
  warn "WiFi: BCM4360 requires broadcom-sta. Build the wl.ko module manually:"
  warn "  https://www.lwfinger.com/downloads/hybrid-v35_64-nodebug-pcoem-6_30_223_271.tar.gz"
  warn "  make -C /lib/modules/\$(uname -r)/build M=\$(pwd) modules"
  warn "  install -m644 wl.ko /lib/modules/\$(uname -r)/updates/"
  warn "  depmod -a"
  cat > /etc/modprobe.d/broadcom-sta.conf << 'EOF'
blacklist brcmfmac
blacklist brcmsmac
blacklist b43
blacklist b43legacy
blacklist ssb
blacklist bcma
EOF

  # OpenRC: enable seatd at boot
  rc-update add seatd default 2>/dev/null || true

  mark_step macbook_hw
fi

echo -e "\n${GREEN}BLFS setup complete.${NC}"
echo -e "${CYAN}Estimated build time on MacBook Air 6,2: 12-20 hours (LLVM is the main bottleneck).${NC}"
echo -e "${CYAN}Reboot into your LFS system and start a niri session as 'legend'.${NC}"

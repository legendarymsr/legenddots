#!/usr/bin/env bash
# Apply legenddots to the running niri session.
# Run as yourself (not root) from inside niri.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "$REPO" && git pull

mkdir -p ~/Pictures/Screenshots ~/.config/alacritty ~/.config/niri ~/.config/nvim
ln -sfn "$REPO/alacritty.toml"  ~/.config/alacritty/alacritty.toml
ln -sfn "$REPO/.zshrc"          ~/.zshrc
ln -sfn "$REPO/init.lua"        ~/.config/nvim/init.lua
ln -sfn "$REPO/niri/config.kdl" ~/.config/niri/config.kdl
ln -sfn "$REPO/niri/waybar"     ~/.config/waybar
ln -sfn "$REPO/niri/fuzzel"     ~/.config/fuzzel
ln -sfn "$REPO/niri/dunst"      ~/.config/dunst
ln -sfn "$REPO/niri/swaylock"   ~/.config/swaylock
ln -sfn "$REPO/wallpapers"      ~/.config/wallpapers

WALLPAPER="$REPO/wallpapers/6orjlq.jpg"
if [[ ! -f "$WALLPAPER" ]]; then
    echo "Wallpaper file missing: $WALLPAPER"
    echo "Run: cd $REPO && git pull"
    exit 1
fi

pkill swaybg 2>/dev/null || true
sleep 0.5
nohup swaybg -m fill -i "$WALLPAPER" >/dev/null 2>&1 &
disown

pgrep -u "$(id -u)" pipewire       >/dev/null || { nohup pipewire       >/dev/null 2>&1 & disown; }
pgrep -u "$(id -u)" pipewire-pulse >/dev/null || { nohup pipewire-pulse >/dev/null 2>&1 & disown; }
pgrep -u "$(id -u)" wireplumber    >/dev/null || { nohup wireplumber    >/dev/null 2>&1 & disown; }

echo "Done."

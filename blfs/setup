# =============================================================================
# 29. seatd
# =============================================================================
if ! step_done seatd; then
  header "seatd ${SEATD_VER}"
  a=$(fetch "https://git.sr.ht/~kennylevinsen/seatd/archive/${SEATD_VER}.tar.gz")
  bpkg "$a" bash -c "
    mkdir build && cd build
    meson setup --prefix=/usr --buildtype=release \
      -D server=enabled -D builtin=enabled -D examples=disabled ..
    ninja -j${NPROC} && ninja install
  "
  install -dm755 /etc/rc.d/init.d /etc/rc.d/rc3.d
  cat > /etc/rc.d/init.d/seatd << 'EOF'
#!/bin/sh
### BEGIN INIT INFO
# Provides:          seatd
# Required-Start:    $local_fs
# Required-Stop:     $local_fs
# Default-Start:     3 5
# Default-Stop:      0 1 2 6
# Short-Description: Seat management daemon
### END INIT INFO

DAEMON=/usr/bin/seatd
PIDFILE=/run/seatd.pid

case "$1" in
  start)
    printf 'Starting seatd... '
    "$DAEMON" -g seat &
    echo $! > "$PIDFILE"
    echo 'done'
    ;;
  stop)
    printf 'Stopping seatd... '
    kill "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null || true
    rm -f "$PIDFILE"
    echo 'done'
    ;;
  status)
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
      echo 'seatd is running'
    else
      echo 'seatd is not running'; exit 1
    fi
    ;;
  restart) $0 stop; sleep 1; $0 start ;;
  *) echo "Usage: $0 {start|stop|status|restart}"; exit 1 ;;
esac
EOF
  chmod 755 /etc/rc.d/init.d/seatd
  ln -sfv /etc/rc.d/init.d/seatd /etc/rc.d/rc3.d/S30seatd
  groupadd -f seat
  mark_step seatd
fi


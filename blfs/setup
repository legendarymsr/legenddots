  bpkg "$a" bash -c "
    mkdir build && cd build
    meson setup --prefix=/usr          \
                --buildtype=release     \
                -D elogind=enabled      \
                -D systemd=disabled     \
                -D tests=disabled       \
                -D doc=disabled         \
                ..
    ninja -j${NPROC}
    ninja install
  "
  mark_step wireplumber

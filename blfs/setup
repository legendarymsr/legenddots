  header "D-Bus ${DBUS_VER}"
  a=$(fetch "https://dbus.freedesktop.org/releases/dbus/dbus-${DBUS_VER}.tar.xz")
  bpkg "$a" bash -c "
    ./configure --prefix=/usr --sysconfdir=/etc --localstatedir=/var \
      --disable-static --disable-doxygen-docs --disable-xml-docs \
      --with-systemdsystemunitdir=no --with-console-auth-dir=/run/console
    make -j${NPROC} && make install
    ln -sfv /etc/machine-id /var/lib/dbus/machine-id 2>/dev/null || true
  "
  mark_step dbus
fi


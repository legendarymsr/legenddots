# ── Phase 2: Temporary tools ──────────────────────────────────────────────────

p2() {
  local name="$1" arc="$2"; shift 2
  done "$name" && return 0
  echo "==> $name (temp)"
  bpkg "$arc" "$@"
  mark "$name"
}


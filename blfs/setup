  header "GTK+ ${GTK3_VER}"
  a=$(fetch "$(gnome_url gtk+ ${GTK3_VER})")
  bpkg "$a" bash -c "
    mkdir build && cd build
    meson setup --prefix=/usr          \
                --buildtype=release     \
                -D introspection=false  \
                -D wayland-backend=true \
                -D x11-backend=false    \
                -D broadway-backend=false \
                -D demos=false          \
                -D examples=false       \
                -D tests=false          \
                ..
    ninja -j${NPROC}
    ninja install
  "
  mark_step gtk3
fi

# =============================================================================
# 25. Rust toolchain (needed by librsvg, niri, alacritty)
# =============================================================================
if ! step_done rust; then
  header "Rust toolchain"
  if ! command -v rustc &>/dev/null; then
    fetch "https://static.rust-lang.org/rustup/dist/x86_64-unknown-linux-gnu/rustup-init"
    chmod +x "$SOURCES/rustup-init"
    RUSTUP_HOME=/usr/share/rustup CARGO_HOME=/usr/share/cargo \
      "$SOURCES/rustup-init" -y --no-modify-path \
        --default-toolchain stable \
        --profile minimal
  fi
  cat > /etc/profile.d/rust.sh << 'EOF'
export RUSTUP_HOME=/usr/share/rustup
export CARGO_HOME=/usr/share/cargo
export PATH="$CARGO_HOME/bin:$PATH"
EOF
  source /etc/profile.d/rust.sh
  mark_step rust
fi
source /etc/profile.d/rust.sh 2>/dev/null || true

# =============================================================================
# 26. librsvg (needs Rust + GTK3 chain)
# =============================================================================
if ! step_done librsvg; then
  header "librsvg ${LIBRSVG_VER}"
  a=$(fetch "$(gnome_url librsvg ${LIBRSVG_VER})")
  bpkg "$a" bash -c "
    ./configure --prefix=/usr   \
                --disable-static \
                --disable-introspection \
                --disable-vala
    make -j${NPROC}
    make install
  "
  mark_step librsvg
fi

# =============================================================================
# 27. LLVM (required by Mesa iris driver — WARNING: very long build ~4-8h)
# =============================================================================
if ! step_done llvm; then
  header "LLVM ${LLVM_VER}"
  warn "LLVM build takes 4-8 hours on this hardware. Go get coffee."
  a=$(fetch "https://github.com/llvm/llvm-project/releases/download/llvmorg-${LLVM_VER}/llvm-${LLVM_VER}.src.tar.xz")
  cf=$(fetch "https://github.com/llvm/llvm-project/releases/download/llvmorg-${LLVM_VER}/cmake-${LLVM_VER}.src.tar.xz")
  bdir=$(mktemp -d "$SOURCES/llvm-build.XXXXXX")
  tar -xf "$a"  -C "$bdir" --strip-components=1
  mkdir -p "$bdir/cmake/modules"
  tar -xf "$cf" --strip-components=1 -C "$bdir/cmake"
  pushd "$bdir" >/dev/null
  mkdir build && cd build
  cmake -DCMAKE_INSTALL_PREFIX=/usr              \
        -DCMAKE_BUILD_TYPE=Release               \
        -DLLVM_ENABLE_FFI=ON                     \
        -DLLVM_BUILD_LLVM_DYLIB=ON               \
        -DLLVM_LINK_LLVM_DYLIB=ON                \
        -DLLVM_ENABLE_RTTI=ON                    \
        -DLLVM_TARGETS_TO_BUILD="X86"            \
        -DLLVM_BINUTILS_INCDIR=/usr/include      \
        -DLLVM_ENABLE_BINDINGS=OFF               \
        -Wno-dev -G Ninja ..
  ninja -j${NPROC}
  ninja install
  popd >/dev/null
  rm -rf "$bdir"
  mark_step llvm
fi

# =============================================================================
# 28. Mesa (Intel iris — requires LLVM above)
# =============================================================================
if ! step_done mesa; then
  header "Mesa ${MESA_VER}"
  a=$(fetch "https://mesa.freedesktop.org/archive/mesa-${MESA_VER}.tar.xz")
  bpkg "$a" bash -c "
    mkdir build && cd build
    meson setup --prefix=/usr            \
                --buildtype=release       \
                -D platforms=wayland      \
                -D gallium-drivers=iris,crocus,swrast \
                -D vulkan-drivers=intel   \
                -D glx=disabled           \
                -D egl=enabled            \
                -D gles1=disabled         \
                -D gles2=enabled          \
                -D llvm=enabled           \
                -D shared-llvm=enabled    \
                -D video-codecs=all       \
                -D intel-clc=auto         \
                ..
    ninja -j${NPROC}
    ninja install
  "
  mark_step mesa
fi

# =============================================================================
# 29. seatd
# =============================================================================
if ! step_done seatd; then
  header "seatd ${SEATD_VER}"
  a=$(fetch "https://git.sr.ht/~kennylevinsen/seatd/archive/${SEATD_VER}.tar.gz")
  bpkg "$a" bash -c "
    mkdir build && cd build
    meson setup --prefix=/usr          \
                --buildtype=release     \
                -D server=enabled       \
                -D builtin=enabled      \
                -D examples=disabled    \
                ..
    ninja -j${NPROC}
    ninja install
  "
  # seatd OpenRC service
  cat > /etc/init.d/seatd << 'EOF'
#!/sbin/openrc-run
description="Seat management daemon"
command="/usr/bin/seatd"
command_args="-g seat"
pidfile="/run/seatd.pid"
command_background=true
depend() { need localmount; }
EOF
  chmod 755 /etc/init.d/seatd
  groupadd -f seat
  rc-update add seatd default 2>/dev/null || true
  mark_step seatd
fi

# =============================================================================
# 30. polkit
# =============================================================================
if ! step_done polkit; then
  header "polkit ${POLKIT_VER}"
  a=$(fetch "https://gitlab.freedesktop.org/polkit/polkit/-/archive/${POLKIT_VER}/polkit-${POLKIT_VER}.tar.gz")
  bpkg "$a" bash -c "
    groupadd -fg 27 polkitd 2>/dev/null || true
    useradd -c 'PolicyKit Daemon Owner' -d /etc/polkit-1 \
            -u 27 -g polkitd -s /bin/false polkitd 2>/dev/null || true
    mkdir build && cd build
    meson setup --prefix=/usr          \
                --buildtype=release     \
                -D session_tracking=elogind \
                -D introspection=false  \
                -D man=false            \
                ..
    ninja -j${NPROC}
    ninja install
    chown -v root:polkitd /usr/lib/polkit-1/polkitd
    chmod -v  4755        /usr/lib/polkit-1/polkitd
  "
  mark_step polkit
fi

# =============================================================================
# 31. PipeWire
# =============================================================================
if ! step_done pipewire; then
  header "PipeWire ${PIPEWIRE_VER}"
  a=$(fetch "https://gitlab.freedesktop.org/pipewire/pipewire/-/archive/${PIPEWIRE_VER}/pipewire-${PIPEWIRE_VER}.tar.gz")
  bpkg "$a" bash -c "
    mkdir build && cd build
    meson setup --prefix=/usr          \
                --buildtype=release     \
                -D session-managers=[]  \
                -D gstreamer=disabled   \
                -D bluez5=disabled      \
                -D jack=disabled        \
                -D tests=disabled       \
                -D examples=disabled    \
                ..
    ninja -j${NPROC}
    ninja install
  "
  mark_step pipewire
fi

# =============================================================================

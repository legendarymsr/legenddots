#!/usr/bin/env bash
# =============================================================================
# LFS 12.4 + BLFS Desktop Setup — KVM/QEMU (x86_64, 2 vCPU, 4 GB RAM) / Niri + Wayland
#
# Phase 1 (from Gentoo host, as root):
#   LFS_DISK=/dev/sdX bash ~/legenddots/blfs/setup
#   Partitions disk, builds LFS 12.4 base system, then exits with reboot prompt.
#
# Phase 2 (booted into LFS or chrooted, as root):
#   bash ~/legenddots/blfs/setup
#   Builds the full Niri + Wayland desktop stack from source.
#
# Checkpoint files:
#   /var/log/lfs-host.state   — Phase 1 host steps (on Gentoo)
#   /etc/blfs-setup.state     — Phase 2 BLFS steps (in LFS)
#   (lfs_complete marker in /etc/blfs-setup.state separates the two phases)
# =============================================================================
set -euo pipefail

[[ $EUID -eq 0 ]] || { echo "Run as root"; exit 1; }

RED='\033[0;31m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'; YELLOW='\033[0;33m'; NC='\033[0m'
header() { echo -e "\n\033[1m\033[36m── $* ──\033[0m"; }
info()   { echo -e "${CYAN}  → $*${NC}"; }
ok()     { echo -e "${GREEN}  ✓ $*${NC}"; }
warn()   { echo -e "${YELLOW}  ! $*${NC}"; }
die()    { echo -e "${RED}  ✗ $*${NC}"; exit 1; }

# =============================================================================
# PHASE DETECTION
# =============================================================================
LFS=/mnt/lfs

if grep -qx "lfs_complete" /etc/blfs-setup.state 2>/dev/null; then
    LFS_DONE=true
else
    LFS_DONE=false
fi

# =============================================================================
# PHASE 1 — LFS BASE SYSTEM (run from Gentoo host)
# =============================================================================
if [[ "$LFS_DONE" == false ]]; then

LFS_DISK="${LFS_DISK:-}"
LFS_TGT="x86_64-lfs-linux-gnu"
MAKEFLAGS="${MAKEFLAGS:--j2}"

if [[ -z "$LFS_DISK" ]]; then
  echo "Available block devices:"
  lsblk -d -o NAME,SIZE,TYPE | grep disk
  read -rp "Target disk for LFS (e.g. /dev/sdb): " LFS_DISK
fi
[[ -b "$LFS_DISK" ]] || die "$LFS_DISK is not a block device"

HOST_STATE=/var/log/lfs-host.state
touch "$HOST_STATE"
step_done() { grep -qx "$1" "$HOST_STATE"; }
mark_step()  { echo "$1" >> "$HOST_STATE"; }

# ── Host validation ──────────────────────────────────────────────────────────
header "Validating host"

declare -A HOST_PKGS=(
  [gcc]="sys-devel/gcc"
  [g++]="sys-devel/gcc"
  [make]="sys-devel/make"
  [bison]="sys-devel/bison"
  [flex]="sys-devel/flex"
  [gawk]="sys-apps/gawk"
  [grep]="sys-apps/grep"
  [gzip]="app-arch/gzip"
  [m4]="sys-devel/m4"
  [perl]="dev-lang/perl"
  [python3]="dev-lang/python"
  [tar]="app-arch/tar"
  [xz]="app-arch/xz-utils"
  [parted]="sys-block/parted"
  [mkswap]="sys-apps/util-linux"
  [mke2fs]="sys-fs/e2fsprogs"
  [blkid]="sys-apps/util-linux"
)
missing=()
for cmd in "${!HOST_PKGS[@]}"; do
  command -v "$cmd" &>/dev/null || missing+=("${HOST_PKGS[$cmd]} (provides $cmd)")
done
if (( ${#missing[@]} )); then
  echo "Missing host tools. Run: emerge -av ${missing[*]%% *}" >&2
  for m in "${missing[@]}"; do echo "  $m" >&2; done
  exit 1
fi

# Check for mkfs.fat (dosfstools) — may be mkdosfs on older systems
if ! command -v mkfs.fat &>/dev/null && ! command -v mkdosfs &>/dev/null; then
  die "Missing mkfs.fat — emerge sys-fs/dosfstools"
fi
MKFSFAT=$(command -v mkfs.fat || command -v mkdosfs)

# Require wget or curl
if command -v wget &>/dev/null; then
  dl() { wget -q --show-progress -c -O "$1" "$2"; }
elif command -v curl &>/dev/null; then
  dl() { curl -fL --progress-bar -C - -o "$1" "$2"; }
else
  die "Neither wget nor curl found — emerge net-misc/wget"
fi

[[ $(gcc -dumpmachine) == x86_64* ]] || die "Host must be x86_64"
python3 -c 'import sys; assert sys.version_info >= (3,4)' 2>/dev/null \
  || die "python3 >= 3.4 required"
awk --version 2>&1 | grep -q "GNU Awk" || die "gawk (GNU Awk) required — not mawk/nawk"
info "Host OK"

# ── Disk ─────────────────────────────────────────────────────────────────────
if ! step_done disk; then
  header "Partitioning $LFS_DISK"
  warn "This will WIPE $LFS_DISK. Ctrl-C to abort. Sleeping 5s..."
  sleep 5

  parted -s "$LFS_DISK" mklabel gpt
  parted -s "$LFS_DISK" mkpart ESP      fat32    1MiB   513MiB
  parted -s "$LFS_DISK" mkpart swap linux-swap 513MiB  4609MiB
  parted -s "$LFS_DISK" mkpart root    ext4    4609MiB  100%
  parted -s "$LFS_DISK" set 1 esp on

  if [[ "$LFS_DISK" == *nvme* || "$LFS_DISK" == *mmcblk* ]]; then
    EFI="${LFS_DISK}p1"; SWAP="${LFS_DISK}p2"; ROOT="${LFS_DISK}p3"
  else
    EFI="${LFS_DISK}1";  SWAP="${LFS_DISK}2";  ROOT="${LFS_DISK}3"
  fi

  "$MKFSFAT" -F32 "$EFI"
  mkswap        "$SWAP"
  mkfs.ext4 -L LFS "$ROOT"

  swapon "$SWAP"
  mkdir -p "$LFS"
  mount "$ROOT" "$LFS"
  mkdir -p "$LFS/boot/efi"
  mount "$EFI" "$LFS/boot/efi"

  cat > /var/log/lfs-parts.env << EOF
LFS_DISK=$LFS_DISK
EFI=$EFI
SWAP=$SWAP
ROOT=$ROOT
EOF
  mark_step disk
fi

source /var/log/lfs-parts.env 2>/dev/null || true
mountpoint -q "$LFS" || { mount "${ROOT}" "$LFS"; mount "${EFI}" "$LFS/boot/efi"; }

# ── Sources ──────────────────────────────────────────────────────────────────
if ! step_done sources; then
  header "Downloading LFS 12.4 sources"
  mkdir -p "$LFS/sources"
  chmod a+wt "$LFS/sources"

  declare -A PKGS=(
    ["binutils-2.45.tar.xz"]="https://sourceware.org/pub/binutils/releases/binutils-2.45.tar.xz"
    ["gcc-15.2.0.tar.xz"]="https://ftp.gnu.org/gnu/gcc/gcc-15.2.0/gcc-15.2.0.tar.xz"
    ["linux-6.16.1.tar.xz"]="https://www.kernel.org/pub/linux/kernel/v6.x/linux-6.16.1.tar.xz"
    ["glibc-2.42.tar.xz"]="https://ftp.gnu.org/gnu/glibc/glibc-2.42.tar.xz"
    ["mpfr-4.2.2.tar.xz"]="https://ftp.gnu.org/gnu/mpfr/mpfr-4.2.2.tar.xz"
    ["gmp-6.3.0.tar.xz"]="https://ftp.gnu.org/gnu/gmp/gmp-6.3.0.tar.xz"
    ["mpc-1.3.1.tar.gz"]="https://ftp.gnu.org/gnu/mpc/mpc-1.3.1.tar.gz"
    ["m4-1.4.20.tar.xz"]="https://ftp.gnu.org/gnu/m4/m4-1.4.20.tar.xz"
    ["ncurses-6.5-20250809.tgz"]="https://invisible-mirror.net/archives/ncurses/ncurses-6.5-20250809.tgz"
    ["bash-5.3.tar.gz"]="https://ftp.gnu.org/gnu/bash/bash-5.3.tar.gz"
    ["coreutils-9.7.tar.xz"]="https://ftp.gnu.org/gnu/coreutils/coreutils-9.7.tar.xz"
    ["diffutils-3.12.tar.xz"]="https://ftp.gnu.org/gnu/diffutils/diffutils-3.12.tar.xz"
    ["file-5.46.tar.gz"]="https://astron.com/pub/file/file-5.46.tar.gz"
    ["findutils-4.10.0.tar.xz"]="https://ftp.gnu.org/gnu/findutils/findutils-4.10.0.tar.xz"
    ["gawk-5.3.2.tar.xz"]="https://ftp.gnu.org/gnu/gawk/gawk-5.3.2.tar.xz"
    ["grep-3.12.tar.xz"]="https://ftp.gnu.org/gnu/grep/grep-3.12.tar.xz"
    ["gzip-1.14.tar.xz"]="https://ftp.gnu.org/gnu/gzip/gzip-1.14.tar.xz"
    ["make-4.4.1.tar.gz"]="https://ftp.gnu.org/gnu/make/make-4.4.1.tar.gz"
    ["patch-2.8.tar.xz"]="https://ftp.gnu.org/gnu/patch/patch-2.8.tar.xz"
    ["sed-4.9.tar.xz"]="https://ftp.gnu.org/gnu/sed/sed-4.9.tar.xz"
    ["tar-1.35.tar.xz"]="https://ftp.gnu.org/gnu/tar/tar-1.35.tar.xz"
    ["xz-5.8.1.tar.xz"]="https://github.com/tukaani-project/xz/releases/download/v5.8.1/xz-5.8.1.tar.xz"
    ["gettext-0.26.tar.xz"]="https://ftp.gnu.org/gnu/gettext/gettext-0.26.tar.xz"
    ["bison-3.8.2.tar.xz"]="https://ftp.gnu.org/gnu/bison/bison-3.8.2.tar.xz"
    ["perl-5.42.0.tar.xz"]="https://www.cpan.org/src/5.0/perl-5.42.0.tar.xz"
    ["Python-3.13.7.tar.xz"]="https://www.python.org/ftp/python/3.13.7/Python-3.13.7.tar.xz"
    ["texinfo-7.2.tar.xz"]="https://ftp.gnu.org/gnu/texinfo/texinfo-7.2.tar.xz"
    ["util-linux-2.41.1.tar.xz"]="https://www.kernel.org/pub/linux/utils/util-linux/v2.41/util-linux-2.41.1.tar.xz"
    ["zlib-1.3.1.tar.gz"]="https://zlib.net/zlib-1.3.1.tar.gz"
    ["bzip2-1.0.8.tar.gz"]="https://www.sourceware.org/pub/bzip2/bzip2-1.0.8.tar.gz"
    ["lz4-1.10.0.tar.gz"]="https://github.com/lz4/lz4/releases/download/v1.10.0/lz4-1.10.0.tar.gz"
    ["zstd-1.5.7.tar.gz"]="https://github.com/facebook/zstd/releases/download/v1.5.7/zstd-1.5.7.tar.gz"
    ["readline-8.3.tar.gz"]="https://ftp.gnu.org/gnu/readline/readline-8.3.tar.gz"
    ["bc-7.0.3.tar.xz"]="https://github.com/gavinhoward/bc/releases/download/7.0.3/bc-7.0.3.tar.xz"
    ["flex-2.6.4.tar.gz"]="https://github.com/westes/flex/releases/download/v2.6.4/flex-2.6.4.tar.gz"
    ["tcl8.6.16-src.tar.gz"]="https://downloads.sourceforge.net/tcl/tcl8.6.16-src.tar.gz"
    ["expect5.45.4.tar.gz"]="https://downloads.sourceforge.net/expect/expect5.45.4.tar.gz"
    ["dejagnu-1.6.3.tar.gz"]="https://ftp.gnu.org/gnu/dejagnu/dejagnu-1.6.3.tar.gz"
    ["pkgconf-2.5.1.tar.xz"]="https://distfiles.ariadne.space/pkgconf/pkgconf-2.5.1.tar.xz"
    ["attr-2.5.2.tar.gz"]="https://download.savannah.gnu.org/releases/attr/attr-2.5.2.tar.gz"
    ["acl-2.3.2.tar.xz"]="https://download.savannah.gnu.org/releases/acl/acl-2.3.2.tar.xz"
    ["libcap-2.76.tar.xz"]="https://www.kernel.org/pub/linux/libs/security/linux-privs/libcap2/libcap-2.76.tar.xz"
    ["libxcrypt-4.4.38.tar.xz"]="https://github.com/besser82/libxcrypt/releases/download/v4.4.38/libxcrypt-4.4.38.tar.xz"
    ["shadow-4.18.0.tar.xz"]="https://github.com/shadow-maint/shadow/releases/download/4.18.0/shadow-4.18.0.tar.xz"
    ["psmisc-23.7.tar.xz"]="https://downloads.sourceforge.net/psmisc/psmisc-23.7.tar.xz"
    ["libtool-2.5.4.tar.xz"]="https://ftp.gnu.org/gnu/libtool/libtool-2.5.4.tar.xz"
    ["gdbm-1.26.tar.gz"]="https://ftp.gnu.org/gnu/gdbm/gdbm-1.26.tar.gz"
    ["gperf-3.3.tar.gz"]="https://ftp.gnu.org/gnu/gperf/gperf-3.3.tar.gz"
    ["expat-2.7.1.tar.xz"]="https://github.com/libexpat/libexpat/releases/download/R_2_7_1/expat-2.7.1.tar.xz"
    ["inetutils-2.6.tar.xz"]="https://ftp.gnu.org/gnu/inetutils/inetutils-2.6.tar.xz"
    ["less-679.tar.gz"]="https://www.greenwoodsoftware.com/less/less-679.tar.gz"
    ["XML-Parser-2.47.tar.gz"]="https://cpan.metacpan.org/authors/id/T/TO/TODDR/XML-Parser-2.47.tar.gz"
    ["intltool-0.51.0.tar.gz"]="https://launchpad.net/intltool/trunk/0.51.0/+download/intltool-0.51.0.tar.gz"
    ["autoconf-2.72.tar.xz"]="https://ftp.gnu.org/gnu/autoconf/autoconf-2.72.tar.xz"
    ["automake-1.18.1.tar.xz"]="https://ftp.gnu.org/gnu/automake/automake-1.18.1.tar.xz"
    ["openssl-3.5.2.tar.gz"]="https://www.openssl.org/source/openssl-3.5.2.tar.gz"
    ["kmod-34.2.tar.xz"]="https://www.kernel.org/pub/linux/utils/kernel/kmod/kmod-34.2.tar.xz"
    ["elfutils-0.193.tar.bz2"]="https://sourceware.org/ftp/elfutils/0.193/elfutils-0.193.tar.bz2"
    ["libffi-3.5.2.tar.gz"]="https://github.com/libffi/libffi/releases/download/v3.5.2/libffi-3.5.2.tar.gz"
    ["wheel-0.46.1.tar.gz"]="https://pypi.org/packages/source/w/wheel/wheel-0.46.1.tar.gz"
    ["flit_core-3.12.0.tar.gz"]="https://pypi.org/packages/source/f/flit_core/flit_core-3.12.0.tar.gz"
    ["markupsafe-3.0.2.tar.gz"]="https://files.pythonhosted.org/packages/source/M/MarkupSafe/markupsafe-3.0.2.tar.gz"
    ["jinja2-3.1.6.tar.gz"]="https://files.pythonhosted.org/packages/source/J/Jinja2/jinja2-3.1.6.tar.gz"
    ["packaging-25.0.tar.gz"]="https://files.pythonhosted.org/packages/source/p/packaging/packaging-25.0.tar.gz"
    ["setuptools-80.9.0.tar.gz"]="https://files.pythonhosted.org/packages/source/s/setuptools/setuptools-80.9.0.tar.gz"
    ["ninja-1.13.1.tar.gz"]="https://github.com/ninja-build/ninja/archive/refs/tags/v1.13.1.tar.gz"
    ["meson-1.8.3.tar.gz"]="https://github.com/mesonbuild/meson/releases/download/1.8.3/meson-1.8.3.tar.gz"
    ["check-0.15.2.tar.gz"]="https://github.com/libcheck/check/releases/download/0.15.2/check-0.15.2.tar.gz"
    ["groff-1.23.0.tar.gz"]="https://ftp.gnu.org/gnu/groff/groff-1.23.0.tar.gz"
    ["iproute2-6.16.0.tar.xz"]="https://www.kernel.org/pub/linux/utils/net/iproute2/iproute2-6.16.0.tar.xz"
    ["kbd-2.8.0.tar.xz"]="https://www.kernel.org/pub/linux/utils/kbd/kbd-2.8.0.tar.xz"
    ["libpipeline-1.5.8.tar.gz"]="https://download.savannah.gnu.org/releases/libpipeline/libpipeline-1.5.8.tar.gz"
    ["vim-9.1.1629.tar.gz"]="https://github.com/vim/vim/archive/refs/tags/v9.1.1629.tar.gz"
    ["eudev-3.2.14.tar.gz"]="https://github.com/eudev-project/eudev/releases/download/v3.2.14/eudev-3.2.14.tar.gz"
    ["man-db-2.13.1.tar.xz"]="https://download.savannah.gnu.org/releases/man-db/man-db-2.13.1.tar.xz"
    ["man-pages-6.15.tar.xz"]="https://www.kernel.org/pub/linux/docs/man-pages/man-pages-6.15.tar.xz"
    ["procps-ng-4.0.5.tar.xz"]="https://sourceforge.net/projects/procps-ng/files/Production/procps-ng-4.0.5.tar.xz"
    ["e2fsprogs-1.47.3.tar.gz"]="https://downloads.sourceforge.net/project/e2fsprogs/e2fsprogs/v1.47.3/e2fsprogs-1.47.3.tar.gz"
    ["sysklogd-2.7.2.tar.gz"]="https://github.com/troglobit/sysklogd/releases/download/v2.7.2/sysklogd-2.7.2.tar.gz"
    ["sysvinit-3.14.tar.xz"]="https://github.com/slicer69/sysvinit/releases/download/3.14/sysvinit-3.14.tar.xz"
    ["iana-etc-20250807.tar.gz"]="https://github.com/Mic92/iana-etc/releases/download/20250807/iana-etc-20250807.tar.gz"
    ["cmake-3.30.2.tar.gz"]="https://cmake.org/files/v3.30/cmake-3.30.2.tar.gz"
    ["git-2.46.0.tar.xz"]="https://www.kernel.org/pub/software/scm/git/git-2.46.0.tar.xz"
    ["wget-1.24.5.tar.gz"]="https://ftp.gnu.org/gnu/wget/wget-1.24.5.tar.gz"
    ["zsh-5.9.tar.xz"]="https://www.zsh.org/pub/zsh-5.9.tar.xz"
    ["opendoas-6.8.2.tar.gz"]="https://github.com/Duncaen/OpenDoas/releases/download/v6.8.2/opendoas-6.8.2.tar.gz"
    ["curl-8.9.1.tar.xz"]="https://curl.se/download/curl-8.9.1.tar.xz"
  )

  for f in "${!PKGS[@]}"; do
    out="$LFS/sources/$f"
    [[ -f "$out" ]] && continue
    info "Downloading $f..."
    dl "$out" "${PKGS[$f]}" || warn "Failed: $f"
  done

  for url in \
    "https://www.linuxfromscratch.org/patches/lfs/12.4/bzip2-1.0.8-install_docs-1.patch" \
    "https://www.linuxfromscratch.org/patches/lfs/12.4/glibc-2.42-fhs-1.patch" \
    "https://www.linuxfromscratch.org/patches/lfs/12.4/kbd-2.8.0-backspace-1.patch"; do
    out="$LFS/sources/$(basename "$url")"
    [[ -f "$out" ]] || dl "$out" "$url" || warn "Failed patch: $(basename "$url")"
  done

  mark_step sources
fi

# ── LFS directory layout + lfs user ─────────────────────────────────────────
if ! step_done lfs_env; then
  header "Setting up LFS build environment"
  mkdir -pv "$LFS"/{etc,var} "$LFS/usr"/{bin,lib,sbin}
  for d in bin lib sbin; do ln -sfv "usr/$d" "$LFS/$d" 2>/dev/null || true; done
  mkdir -pv "$LFS/lib64" "$LFS/tools"

  groupadd -f lfs
  useradd -s /bin/bash -g lfs -m -k /dev/null lfs 2>/dev/null || true
  chown -v lfs "$LFS/"{usr{,/*},lib,lib64,var,etc,bin,sbin,tools,sources}

  cat > /home/lfs/.bash_profile << 'EOF'
exec env -i HOME=$HOME TERM=$TERM PS1='\u:\w\$ ' /bin/bash
EOF
  cat > /home/lfs/.bashrc << EOF
set +h
umask 022
LFS=$LFS
LC_ALL=POSIX
LFS_TGT=$LFS_TGT
PATH=/usr/bin
if [ ! -L /bin ]; then PATH=/bin:\$PATH; fi
PATH=\$LFS/tools/bin:\$PATH
CONFIG_SITE=\$LFS/usr/share/config.site
export LFS LC_ALL LFS_TGT PATH CONFIG_SITE
MAKEFLAGS="$MAKEFLAGS"
export MAKEFLAGS
EOF
  chown lfs /home/lfs/.bash_profile /home/lfs/.bashrc
  mark_step lfs_env
fi

# =============================================================================
# PHASE 1a — Cross-toolchain + Temporary Tools (runs as lfs user)
# =============================================================================
cat > /tmp/lfs-phase12.sh << 'PHASE12'
#!/bin/bash
set -euo pipefail
source ~/.bashrc

LFS="${LFS:-/mnt/lfs}"
LFS_TGT="${LFS_TGT:-x86_64-lfs-linux-gnu}"
SRC="$LFS/sources"
MAKEFLAGS="${MAKEFLAGS:--j3}"

STATE="$HOME/.lfs-phase12.state"
touch "$STATE"
done() { grep -qx "$1" "$STATE"; }
mark() { echo "$1" >> "$STATE"; }

bpkg() {
  local arc="$1"; shift
  local d; d=$(mktemp -d "$SRC/build.XXXXXX")
  tar -xf "$arc" -C "$d" --strip-components=1
  pushd "$d" >/dev/null
  "$@"
  popd >/dev/null
  rm -rf "$d"
}

# ── Phase 1: Cross-toolchain ──────────────────────────────────────────────────

if ! done binutils_p1; then
  echo "==> Binutils (pass 1)"
  bpkg "$SRC/binutils-2.45.tar.xz" bash -c "
    mkdir build && cd build
    ../configure --prefix=\$LFS/tools --with-sysroot=\$LFS --target=\$LFS_TGT \
      --disable-nls --enable-gprofng=no --disable-werror \
      --enable-new-dtags --enable-default-hash-style=gnu
    make \$MAKEFLAGS && make install
  "
  mark binutils_p1
fi

if ! done gcc_p1; then
  echo "==> GCC (pass 1)"
  bpkg "$SRC/gcc-15.2.0.tar.xz" bash -c "
    tar -xf \$SRC/mpfr-4.2.2.tar.xz && mv mpfr-4.2.2 mpfr
    tar -xf \$SRC/gmp-6.3.0.tar.xz  && mv gmp-6.3.0  gmp
    tar -xf \$SRC/mpc-1.3.1.tar.gz  && mv mpc-1.3.1  mpc
    sed -e '/m64=/s/lib64/lib/' -i.orig gcc/config/i386/t-linux64
    mkdir build && cd build
    ../configure --target=\$LFS_TGT --prefix=\$LFS/tools \
      --with-glibc-version=2.42 --with-sysroot=\$LFS --with-newlib \
      --without-headers --enable-default-pie --enable-default-ssp \
      --disable-nls --disable-shared --disable-multilib --disable-threads \
      --disable-libatomic --disable-libgomp --disable-libquadmath \
      --disable-libssp --disable-libvtv --disable-libstdcxx \
      --enable-languages=c,c++
    make \$MAKEFLAGS && make install
    cd ..
    cat gcc/limitx.h gcc/glimits.h gcc/limity.h > \
      \$(\$LFS_TGT-gcc -print-libgcc-file-name | sed 's/libgcc/limits/')
  "
  mark gcc_p1
fi

if ! done linux_headers; then
  echo "==> Linux API headers"
  bpkg "$SRC/linux-6.16.1.tar.xz" bash -c "
    make mrproper && make headers
    find usr/include -type f ! -name '*.h' -delete
    cp -rv usr/include \$LFS/usr
  "
  mark linux_headers
fi

if ! done glibc; then
  echo "==> Glibc"
  bpkg "$SRC/glibc-2.42.tar.xz" bash -c "
    ln -sfnv ../lib/ld-linux-x86-64.so.2 \$LFS/lib64
    ln -sfnv ../lib/ld-linux-x86-64.so.2 \$LFS/lib64/ld-lsb-x86-64.so.3
    patch -Np1 -i \$SRC/glibc-2.42-fhs-1.patch
    mkdir build && cd build
    echo rootsbindir=/usr/sbin > configparms
    ../configure --prefix=/usr --host=\$LFS_TGT \
      --build=\$(../scripts/config.guess) --enable-kernel=4.19 \
      --with-headers=\$LFS/usr/include --disable-nscd libc_cv_slibdir=/usr/lib
    make \$MAKEFLAGS && make DESTDIR=\$LFS install
    sed '/RTLDLIST=/s@/usr@@g' -i \$LFS/usr/bin/ldd
  "
  mark glibc
fi


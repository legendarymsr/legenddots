PHASE12

chmod +x /tmp/lfs-phase12.sh

if ! step_done phase12; then
  header "Phase 1 & 2 — cross-toolchain + temp tools (as lfs user)"
  su - lfs -c "bash /tmp/lfs-phase12.sh"
  mark_step phase12
fi

# =============================================================================
# PHASE 1b — Virtual filesystems
# =============================================================================
if ! step_done vfs_mount; then
  header "Mounting virtual filesystems"
  mkdir -pv "$LFS"/{dev,proc,sys,run}
  mount -v --bind /dev       "$LFS/dev"
  mount -vt devpts devpts    "$LFS/dev/pts" -o gid=5,mode=0620
  mount -vt proc  proc       "$LFS/proc"
  mount -vt sysfs sysfs      "$LFS/sys"
  mount -vt tmpfs tmpfs      "$LFS/run"
  [[ -h "$LFS/dev/shm" ]] && install -v -d -m 1777 "$LFS/$(readlink "$LFS/dev/shm")"
  mark_step vfs_mount
elif ! mountpoint -q "$LFS/proc"; then
  # Host was rebooted — mounts are gone but step is marked done; remount
  header "Remounting virtual filesystems after host reboot"
  mount -v --bind /dev       "$LFS/dev"
  mount -vt devpts devpts    "$LFS/dev/pts" -o gid=5,mode=0620
  mount -vt proc  proc       "$LFS/proc"
  mount -vt sysfs sysfs      "$LFS/sys"
  mount -vt tmpfs tmpfs      "$LFS/run"
  [[ -h "$LFS/dev/shm" ]] && install -v -d -m 1777 "$LFS/$(readlink "$LFS/dev/shm")"
fi

# =============================================================================
# PHASE 1c — Base system in chroot
# =============================================================================
mkdir -p "$LFS/tmp"
cat > "$LFS/tmp/lfs-chroot.sh" << 'CHROOT'
#!/bin/bash
set -euo pipefail
export HOME=/root TERM=$TERM PS1='(lfs chroot) \u:\w\$ '
export PATH=/usr/sbin:/usr/bin:/sbin:/bin
export MAKEFLAGS="${MAKEFLAGS:--j3}"
SRC=/sources

STATE=/tmp/lfs-chroot.state
touch "$STATE"
done() { grep -qx "$1" "$STATE"; }
mark() { echo "$1" >> "$STATE"; }

bpkg() {
  local arc="$1"; shift
  local d; d=$(mktemp -d "$SRC/build.XXXXXX")
  tar -xf "$arc" -C "$d" --strip-components=1
  pushd "$d" >/dev/null
  "$@"
  popd >/dev/null
  rm -rf "$d"
}

pkg() { local n="$1" a="$2"; shift 2; done "$n" && return 0; echo "==> $n"; bpkg "$a" "$@"; mark "$n"; }

# ── Initial directory structure ───────────────────────────────────────────────
if ! done chroot_init; then
  mkdir -pv /{boot,home,mnt,opt,srv} /etc/{opt,sysconfig} /lib/firmware
  mkdir -pv /media/{floppy,cdrom} /usr/{,local/}{include,src} /usr/lib/locale
  mkdir -pv /usr/local/{bin,lib,sbin}
  mkdir -pv /usr/{,local/}share/{color,dict,doc,info,locale,man,misc,terminfo,zoneinfo}
  mkdir -pv /usr/{,local/}share/man/man{1..8}
  mkdir -pv /var/{cache,local,log,mail,opt,spool} /var/lib/{color,misc,locate}
  ln -sfv /run /var/run; ln -sfv /run/lock /var/lock
  install -dv -m 0750 /root; install -dv -m 1777 /tmp /var/tmp
  ln -sv /proc/self/mounts /etc/mtab

  cat > /etc/hosts << 'EOF'
127.0.0.1 localhost
127.0.1.1 lfs
::1       localhost ip6-localhost ip6-loopback
EOF

  cat > /etc/passwd << 'EOF'
root:x:0:0:root:/root:/bin/bash
bin:x:1:1:bin:/dev/null:/usr/bin/false
daemon:x:6:6:Daemon User:/dev/null:/usr/bin/false
messagebus:x:18:18:D-Bus Message Daemon User:/run/dbus:/usr/bin/false
uuidd:x:80:80:UUID Generation Daemon User:/dev/null:/usr/bin/false
nobody:x:65534:65534:Unprivileged User:/dev/null:/usr/bin/false
EOF

  cat > /etc/group << 'EOF'
root:x:0:
bin:x:1:root,bin,daemon
daemon:x:6:root,bin,daemon
sys:x:8:
audio:x:11:
video:x:12:
cdrom:x:15:
usb:x:85:
utmp:x:43:
users:x:999:
nogroup:x:65533:
nobody:x:65534:
EOF

  for f in /var/log/{btmp,lastlog,faillog,wtmp}; do touch "$f"; done
  chgrp -v utmp /var/log/lastlog; chmod -v 664 /var/log/lastlog; chmod -v 600 /var/log/btmp
  mark chroot_init
fi


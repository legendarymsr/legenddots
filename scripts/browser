#!/usr/bin/env python3
"""
Terminal browser — works on Termux (Android) and desktop.

Termux setup:
    pkg install python ca-certificates
    pip install textual httpx html2text beautifulsoup4
"""

import sys

try:
    from textual.app import App, ComposeResult
    from textual.widgets import Input, Markdown, Header, Footer
    from textual.containers import VerticalScroll
    from textual.binding import Binding
    import httpx
    import html2text
    from bs4 import BeautifulSoup
except ImportError as e:
    print(f"\nMissing dependency: {e}")
    print("\nInstall with:")
    print("  Termux:   pkg install python ca-certificates")
    print("            pip install textual httpx html2text beautifulsoup4")
    print("  Desktop:  pip install textual httpx html2text beautifulsoup4")
    sys.exit(1)


class LegendBrowser(App):
    CSS = """
    Screen {
        background: #1a1b26;
        color: #c0caf5;
    }

    Input {
        dock: top;
        height: 3;
        margin: 0 0 1 0;
        border: heavy #7aa2f7;
        background: #15161e;
        color: #c0caf5;
    }
    Input:focus { border: heavy #bb9af7; }

    VerticalScroll {
        width: 100%;
        height: 1fr;
    }

    Markdown {
        background: #1a1b26;
        color: #c0caf5;
        padding: 1 2;
    }

    MarkdownH1 {
        color: #f7768e;
        text-style: bold;
        background: #1a1b26;
        border: heavy #f7768e;
        padding: 1;
    }

    MarkdownLink {
        color: #7dcfff;
        text-style: underline;
    }

    MarkdownFence {
        background: #15161e;
        border: solid #9ece6a;
        color: #9ece6a;
    }
    """

    BINDINGS = [
        Binding("q", "quit", "Quit"),
        Binding("ctrl+l", "focus_url", "URL bar"),
        Binding("j", "scroll_down", "Down", show=False),
        Binding("k", "scroll_up", "Up", show=False),
        Binding("ctrl+d", "page_down", "Page ↓", show=False),
        Binding("ctrl+u", "page_up", "Page ↑", show=False),
        Binding("g", "scroll_home", "Top", show=False),
        Binding("G", "scroll_end", "Bottom", show=False),
        Binding("r", "reload", "Reload"),
    ]

    def __init__(self):
        super().__init__()
        self._current_url: str = ""

    def compose(self) -> ComposeResult:
        yield Header(show_clock=True)
        yield Input(placeholder="Enter URL — press Enter to load", id="address_bar")
        with VerticalScroll(id="scroll", can_focus=True):
            yield Markdown("# SYSTEM READY\n\nType a URL above and press Enter.", id="content")
        yield Footer()

    def on_mount(self) -> None:
        self.query_one("#address_bar", Input).focus()

    def action_focus_url(self) -> None:
        self.query_one("#address_bar", Input).focus()

    def action_scroll_down(self) -> None:
        self.query_one("#scroll", VerticalScroll).scroll_down()

    def action_scroll_up(self) -> None:
        self.query_one("#scroll", VerticalScroll).scroll_up()

    def action_page_down(self) -> None:
        self.query_one("#scroll", VerticalScroll).scroll_page_down()

    def action_page_up(self) -> None:
        self.query_one("#scroll", VerticalScroll).scroll_page_up()

    def action_scroll_home(self) -> None:
        self.query_one("#scroll", VerticalScroll).scroll_home()

    def action_scroll_end(self) -> None:
        self.query_one("#scroll", VerticalScroll).scroll_end()

    async def action_reload(self) -> None:
        if self._current_url:
            await self.fetch_url(self._current_url)

    async def on_input_submitted(self, message: Input.Submitted) -> None:
        url = message.value.strip()
        if not url:
            return
        if not url.startswith(("http://", "https://")):
            url = "https://" + url
        await self.fetch_url(url)

    async def fetch_url(self, url: str) -> None:
        content = self.query_one("#content", Markdown)
        bar = self.query_one("#address_bar", Input)
        await content.update(f"# Loading…\n\n`{url}`")
        try:
            async with httpx.AsyncClient(
                follow_redirects=True,
                timeout=15.0,
            ) as client:
                response = await client.get(url)

            self._current_url = str(response.url)
            bar.value = self._current_url

            soup = BeautifulSoup(response.text, "html.parser")

            for span in soup.find_all("span", class_="microsoft"):
                span.string = f"~~{span.get_text()}~~"

            converter = html2text.HTML2Text()
            converter.ignore_links = False
            converter.body_width = 0
            md = converter.handle(str(soup))

            await content.update(md)
            scroll = self.query_one("#scroll", VerticalScroll)
            scroll.scroll_home(animate=False)
            scroll.focus()

        except httpx.SSLError:
            await content.update(
                "# SSL Error\n\nCertificate verification failed.\n\n"
                "**On Termux:** run `pkg install ca-certificates` then retry.\n\n"
                "Or prefix the URL with `http://` to skip HTTPS."
            )
            self.query_one("#scroll", VerticalScroll).focus()
        except httpx.ConnectError as e:
            await content.update(f"# Connection Error\n\n{e}")
            self.query_one("#scroll", VerticalScroll).focus()
        except httpx.TimeoutException:
            await content.update(f"# Timeout\n\nNo response from `{url}` within 15s.")
            self.query_one("#scroll", VerticalScroll).focus()
        except Exception as e:
            await content.update(f"# Error\n\n```\n{type(e).__name__}: {e}\n```")
            self.query_one("#scroll", VerticalScroll).focus()


if __name__ == "__main__":
    LegendBrowser().run()

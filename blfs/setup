# ── System configuration ───────────────────────────────────────────────────────
if ! done sysconfig; then
  echo "==> System configuration"
  ROOT_UUID=$(blkid -s UUID -o value $ROOT 2>/dev/null || echo "CHANGEME")
  EFI_UUID=$(blkid  -s UUID -o value $EFI  2>/dev/null || echo "CHANGEME")
  SWAP_UUID=$(blkid -s UUID -o value $SWAP 2>/dev/null || echo "CHANGEME")

  cat > /etc/fstab << EOF2
UUID=$ROOT_UUID  /         ext4  defaults,noatime 0 1
UUID=$EFI_UUID   /boot/efi vfat  umask=0077       0 2
UUID=$SWAP_UUID  none      swap  sw               0 0
tmpfs            /tmp      tmpfs defaults          0 0
EOF2

  echo "lfs" > /etc/hostname

  cat > /etc/inittab << 'EOF2'
id:3:initdefault:
si::sysinit:/etc/rc.d/init.d/rc sysinit
l0:0:wait:/etc/rc.d/init.d/rc 0
l3:3:wait:/etc/rc.d/init.d/rc 3
l6:6:wait:/etc/rc.d/init.d/rc 6
ca:12345:ctrlaltdel:/sbin/shutdown -t1 -a -r now
su:S016:once:/sbin/sulogin
1:2345:respawn:/sbin/agetty --noclear tty1 9600
2:2345:respawn:/sbin/agetty tty2 9600
EOF2

  mkdir -pv /etc/profile.d
  cat > /etc/profile << 'EOF2'
for script in /etc/profile.d/*.sh; do
  [ -r "$script" ] && . "$script"
done
unset script
EOF2

  cat > /etc/profile.d/locale.sh << 'EOF2'
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
EOF2

  cat > /etc/inputrc << 'EOF2'
set horizontal-scroll-mode Off
set meta-flag On
set input-meta On
set convert-meta Off
set output-meta On
set bell-style none
"\eOd": backward-word
"\eOc": forward-word
"\e[1~": beginning-of-line
"\e[4~": end-of-line
"\e[3~": delete-char
"\e[2~": quoted-insert
EOF2

  cat > /etc/shells << 'EOF2'
/bin/sh
/bin/bash
EOF2

  echo 'root:legendary123' | chpasswd
  mark sysconfig
fi


fetch() {
  local url="$1"
  local out="$SOURCES/$(basename "$url")"
  if [[ ! -f "$out" ]]; then
    info "Fetching $(basename "$url")..."
    wget -q --show-progress -c -O "$out" "$url" || { rm -f "$out"; die "Download failed: $url"; }
  fi
  echo "$out"
}

bpkg() {
  local archive="$1"; shift
  local bdir; bdir=$(mktemp -d "$SOURCES/build.XXXXXX")
  tar -xf "$archive" -C "$bdir" --strip-components=1
  pushd "$bdir" >/dev/null
  "$@"
  local rc=$?
  popd >/dev/null
  rm -rf "$bdir"
  return $rc
}

gnome_url() {
  local pkg="$1" ver="$2"
  local minor="${ver%.*}"
  echo "https://download.gnome.org/sources/${pkg}/${minor}/${pkg}-${ver}.tar.xz"
}


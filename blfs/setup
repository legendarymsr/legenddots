#!/usr/bin/env bash
# =============================================================================
# BLFS Desktop Setup — MacBook Air 6,2 / Niri + Wayland
# Builds the full desktop stack from source following BLFS procedures.
#
# Prerequisites: LFS 12.x base system with gcc, make, cmake, meson, ninja,
#   pkg-config, python3, perl, bison, flex, gperf, diffutils, patch, which.
#
# Run as root inside the LFS environment (chroot or booted LFS partition).
# Re-runnable: completed steps are skipped via /etc/blfs-setup.state.
# =============================================================================
set -euo pipefail

[[ $EUID -eq 0 ]] || { echo "Run as root"; exit 1; }

# ── Colors & helpers ──────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'; YELLOW='\033[0;33m'; NC='\033[0m'
header() { echo -e "\n\033[1m\033[36m── $* ──\033[0m"; }
info()   { echo -e "${CYAN}  → $*${NC}"; }
ok()     { echo -e "${GREEN}  ✓ $*${NC}"; }
warn()   { echo -e "${YELLOW}  ! $*${NC}"; }
die()    { echo -e "${RED}  ✗ $*${NC}"; exit 1; }

# ── Checkpointing ─────────────────────────────────────────────────────────────
STATE_FILE=/etc/blfs-setup.state
touch "$STATE_FILE"
step_done() { grep -qx "$1" "$STATE_FILE"; }
mark_step() { echo "$1" >> "$STATE_FILE"; }

# ── Build environment ─────────────────────────────────────────────────────────
SOURCES=/sources
mkdir -p "$SOURCES"

export CC="gcc"
export CXX="g++"
export CFLAGS="-march=haswell -O2 -pipe"
export CXXFLAGS="-march=haswell -O2 -pipe"
export MAKEFLAGS="-j3"
export PKG_CONFIG_PATH="/usr/lib/pkgconfig:/usr/share/pkgconfig"
export PATH="/usr/sbin:/usr/bin:/sbin:/bin:/usr/local/bin"

NPROC=3  # j3 — safe for 8 GB RAM

# ── Package versions ──────────────────────────────────────────────────────────
# Check https://www.linuxfromscratch.org/blfs/view/stable/ for newer versions.

PCRE2_VER="10.44"
LIBFFI_VER="3.4.6"
LIBUNISTRING_VER="1.2"
GETTEXT_VER="0.22.5"
GLIB_VER="2.82.4"
LIBPNG_VER="1.6.44"
LIBJPEG_TURBO_VER="3.0.4"
LIBTIFF_VER="4.7.0"
LIBWEBP_VER="1.4.0"
LIBDRM_VER="2.4.123"
WAYLAND_VER="1.23.1"
WAYLAND_PROTO_VER="1.37"
XKB_CONFIG_VER="2.43"
XKBCOMMON_VER="1.7.0"
PIXMAN_VER="0.43.4"
FREETYPE_VER="2.13.3"
HARFBUZZ_VER="10.1.0"
FONTCONFIG_VER="2.15.0"
CAIRO_VER="1.18.2"
PANGO_VER="1.54.0"
GDK_PIXBUF_VER="2.42.12"
ATK_VER="2.38.0"
AT_SPI2_CORE_VER="2.54.0"
GTK3_VER="3.24.43"
LIBRSVG_VER="2.58.3"
LLVM_VER="18.1.8"
MESA_VER="24.3.4"
SEATD_VER="0.8.0"
ELOGIND_VER="255.5"
POLKIT_VER="125"
PIPEWIRE_VER="1.2.7"
WIREPLUMBER_VER="0.5.7"
NIRI_VER="0.1.10"
ALACRITTY_VER="0.15.0"
WAYBAR_VER="0.10.4"
FUZZEL_VER="1.10.3"
SWAYLOCK_VER="1.7.2"
SWAYBG_VER="1.2.1"
DUNST_VER="1.11.0"
GRIM_VER="1.4.1"
SLURP_VER="1.5.0"
WL_CLIPBOARD_VER="2.2.1"
BRIGHTNESSCTL_VER="0.5.1"
NETWORKMANAGER_VER="1.50.0"
DBUS_VER="1.14.10"

# ── Download + extract helpers ────────────────────────────────────────────────
fetch() {
  local url="$1"
  local out="$SOURCES/$(basename "$url")"
  if [[ ! -f "$out" ]]; then
    info "Fetching $(basename "$url")..."
    wget -q --show-progress -c -O "$out" "$url" || {
      rm -f "$out"
      die "Download failed: $url"
    }
  fi
  echo "$out"
}

# Extract archive into a temp subdir of SOURCES, cd into it, run commands, clean up.
bpkg() {
  local archive="$1"; shift
  local bdir
  bdir=$(mktemp -d "$SOURCES/build.XXXXXX")
  tar -xf "$archive" -C "$bdir" --strip-components=1
  pushd "$bdir" >/dev/null
  "$@"
  local rc=$?
  popd >/dev/null
  rm -rf "$bdir"
  return $rc
}

gnome_url() {
  # gnome_url <package> <full-version>  →  gnome ftp URL
  local pkg="$1" ver="$2"
  local minor="${ver%.*}"
  echo "https://download.gnome.org/sources/${pkg}/${minor}/${pkg}-${ver}.tar.xz"
}

# =============================================================================
# 1. D-BUS (needed by many packages)
# =============================================================================
if ! step_done dbus; then
  header "D-Bus ${DBUS_VER}"
  a=$(fetch "https://dbus.freedesktop.org/releases/dbus/dbus-${DBUS_VER}.tar.xz")
  bpkg "$a" bash -c "
    ./configure --prefix=/usr          \
                --sysconfdir=/etc      \
                --localstatedir=/var   \
                --disable-static       \
                --disable-doxygen-docs \
                --disable-xml-docs     \
                --with-systemdsystemunitdir=no \
                --with-console-auth-dir=/run/console
    make -j${NPROC}
    make install
    ln -sfv /etc/machine-id /var/lib/dbus/machine-id 2>/dev/null || true
  "
  mark_step dbus
fi

# =============================================================================
# 2. PCRE2
# =============================================================================
if ! step_done pcre2; then
  header "PCRE2 ${PCRE2_VER}"
  a=$(fetch "https://github.com/PCRE2Project/pcre2/releases/download/pcre2-${PCRE2_VER}/pcre2-${PCRE2_VER}.tar.bz2")
  bpkg "$a" bash -c "
    ./configure --prefix=/usr             \
                --enable-unicode          \
                --enable-jit              \
                --enable-pcre2-16         \
                --enable-pcre2-32         \
                --enable-pcre2grep-libz   \
                --enable-pcre2grep-libbz2 \
                --disable-static
    make -j${NPROC}
    make install
  "
  mark_step pcre2
fi


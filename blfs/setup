  mkdir build && pushd build
    ../configure && make -C include && make -C progs tic
  popd
  ./configure --prefix=/usr --host=\$LFS_TGT --build=\$(./config.guess) \
    --mandir=/usr/share/man --with-manpage-format=normal \
    --with-shared --without-normal --with-cxx-shared --without-debug \
    --without-ada --disable-stripping
  make \$MAKEFLAGS && make DESTDIR=\$LFS TIC_PATH=\$(pwd)/build/progs/tic install
  ln -sv libncursesw.so \$LFS/usr/lib/libncurses.so
  sed -e 's/^#if.*XOPEN.*$/\n#if 1/' -i \$LFS/usr/include/curses.h
"


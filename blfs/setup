fi

# =============================================================================
# 35. waybar (needs GTK3, pipewire, wayland)
# =============================================================================
if ! step_done waybar; then
  header "waybar ${WAYBAR_VER}"
  # waybar needs jsoncpp, libxkbregistry, fmt, spdlog, date
  # Install fmt first
  fmt_a=$(fetch "https://github.com/fmtlib/fmt/archive/refs/tags/11.0.2.tar.gz")
  bpkg "$fmt_a" bash -c "
    cmake -DCMAKE_INSTALL_PREFIX=/usr \
          -DCMAKE_BUILD_TYPE=Release   \
          -DFMT_TEST=OFF               \
          -G Ninja .
    ninja -j${NPROC}
    ninja install
  "
  spdlog_a=$(fetch "https://github.com/gabime/spdlog/archive/refs/tags/v1.14.1.tar.gz")
  bpkg "$spdlog_a" bash -c "
    cmake -DCMAKE_INSTALL_PREFIX=/usr \
          -DCMAKE_BUILD_TYPE=Release   \
          -DSPDLOG_FMT_EXTERNAL=ON     \
          -G Ninja .
    ninja -j${NPROC}
    ninja install
  "
  jsoncpp_a=$(fetch "https://github.com/open-source-parsers/jsoncpp/archive/refs/tags/1.9.6.tar.gz")
  bpkg "$jsoncpp_a" bash -c "
    cmake -DCMAKE_INSTALL_PREFIX=/usr   \
          -DCMAKE_BUILD_TYPE=Release     \
          -DJSONCPP_WITH_TESTS=OFF       \
          -DBUILD_SHARED_LIBS=ON         \
          -G Ninja .
    ninja -j${NPROC}
    ninja install
  "
  a=$(fetch "https://github.com/Alexays/Waybar/archive/refs/tags/${WAYBAR_VER}.tar.gz")
  bpkg "$a" bash -c "
    mkdir build && cd build
    meson setup --prefix=/usr          \
                --buildtype=release     \
                -D niri=enabled         \
                -D tray=enabled         \
                -D systemd=disabled     \
                -D pulseaudio=disabled  \
                -D pipewire=enabled     \
                -D mpris=disabled       \
                -D jack=disabled        \
                -D tests=disabled       \
                ..
    ninja -j${NPROC}
    ninja install
  "
  mark_step waybar
fi


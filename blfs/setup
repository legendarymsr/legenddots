echo "==> LFS chroot build complete."
CHROOT

chmod +x "$LFS/tmp/lfs-chroot.sh"

if ! step_done chroot_build; then
  header "Phase 3 — base system in chroot"
  source /var/log/lfs-parts.env
  chroot "$LFS" /usr/bin/env -i \
    HOME=/root TERM="$TERM" PS1='(lfs) \u:\w\$ ' \
    PATH=/usr/sbin:/usr/bin:/sbin:/bin \
    MAKEFLAGS="$MAKEFLAGS" \
    ROOT="$ROOT" EFI="$EFI" SWAP="$SWAP" \
    /bin/bash /tmp/lfs-chroot.sh
  mark_step chroot_build
fi

# ── rEFInd ───────────────────────────────────────────────────────────────────
if ! step_done refind; then
  header "Installing rEFInd"
  if ! command -v refind-install &>/dev/null; then
    warn "refind-install not found on host — install sys-boot/refind on Gentoo first"
    warn "  emerge sys-boot/refind"
    warn "Re-run this script after installing rEFInd to complete the bootloader step."
  else
    source /var/log/lfs-parts.env
    ROOT_UUID=$(blkid -s UUID -o value "$ROOT")
    refind-install --usedefault "$EFI" --root "$LFS"
    cat > "$LFS/boot/efi/EFI/BOOT/refind_linux.conf" << EOF
"Boot LFS" "ro root=UUID=${ROOT_UUID} quiet"
EOF
    mark_step refind
  fi
fi

# ── Mark LFS complete and unmount ────────────────────────────────────────────
mkdir -p "$LFS/etc"
grep -qx "lfs_complete" "$LFS/etc/blfs-setup.state" 2>/dev/null || \
  echo "lfs_complete" >> "$LFS/etc/blfs-setup.state"

header "Unmounting $LFS"
umount -R "$LFS/dev" "$LFS/proc" "$LFS/sys" "$LFS/run" 2>/dev/null || true
umount "$LFS/boot/efi" 2>/dev/null || true
umount "$LFS"          2>/dev/null || true

echo -e "\n${GREEN}── LFS base system complete ──${NC}"
echo "1. Boot from $LFS_DISK (select LFS in rEFInd)"
echo "2. Log in as root (password: legendary123)"
echo "3. Clone legenddots and rerun this script:"
echo "   git clone https://github.com/legendarymsr/legenddots ~/legenddots"
echo "   bash ~/legenddots/blfs/setup"
echo ""
echo "WiFi: BCM4360 requires the broadcom-sta wl.ko module — see blfs/README.md."
exit 0

fi  # end LFS_DONE==false


# IceCat-for-Android branding configuration
# Edit these values to customize the rebrand. Sourced by scripts/*.sh.

# Display name shown to users (launcher, about screen, etc.)
APP_NAME="IceCat"

# Android application ID (reverse-DNS package name baked into the APK).
# This is independent of the upstream Kotlin/Java package structure, so
# changing it does not require renaming source directories.
PACKAGE_ID="org.gnuzilla.icecat"

# Upstream source to build from. VERIFY THIS — the DivestOS Mobile org/repo
# layout changes over time; check https://divestos.org/ or the DivestOS
# GitHub org for the current Mull-Fenix repo before relying on this.
MULL_REPO_URL="https://github.com/divested-mobile/Mull-Fenix.git"
MULL_REF="main"   # pin to a release tag for reproducible builds, e.g. "v118.1.0-mull"

# Gradle assemble task to run. This is a placeholder — after the first
# `scripts/fetch-source.sh`, run `cd src && ./gradlew tasks` to find the real
# flavor/buildType combo (Fenix-based projects usually expose names like
# assembleFenixDebug / assembleFocusRelease) and update this value.
GRADLE_TASK="assembleDebug"

# Where build.sh copies the resulting APK(s).
DIST_DIR="dist"

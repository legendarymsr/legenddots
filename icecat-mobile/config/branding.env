# IceCat-for-Android branding configuration
# Edit these values to customize the rebrand. Sourced by scripts/*.sh.

# Display name shown to users (launcher, about screen, etc.)
APP_NAME="IceCat"

# DivestOS's F-Droid repo, which is where Mull is actually published (Mull
# does NOT publish APKs via GitHub releases). scripts/download-apk.sh reads
# this repo's index-v1.json to find the latest APK for MULL_PACKAGE_ID/MULL_ABI.
MULL_FDROID_REPO="https://fdroid.divestos.org/repo"

# Mull's Android package ID (DivestOS's de-Googled Fenix fork).
MULL_PACKAGE_ID="us.spotco.fennec_dos"

# Device ABI to fetch (arm64-v8a covers most modern phones).
MULL_ABI="arm64-v8a"

# Working/output directories
WORK_DIR="build"
DIST_DIR="dist"

# Signing key used to re-sign the repackaged APK. This is a throwaway key
# committed to the repo (keystore/icecat-release.keystore) — it exists only
# so sideloaded builds from this repo can be reinstalled/updated without
# uninstalling first. It carries no trust; do not treat it as official.
KEYSTORE="keystore/icecat-release.keystore"
KEYSTORE_ALIAS="icecat"
KEYSTORE_PASS="icecat-throwaway"

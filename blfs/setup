    source /etc/profile.d/rust.sh
    cargo build --release --locked
    install -Dm755 target/release/niri /usr/bin/niri
    install -Dm644 resources/niri.desktop \
      /usr/share/wayland-sessions/niri.desktop 2>/dev/null || true
  "
